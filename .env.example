# Duffel flight API (sandbox token starts with "duffel_test_")
# Sign up: https://duffel.com -> Developers -> Access tokens
DUFFEL_ACCESS_TOKEN=duffel_test_REPLACE_ME

# Vercel AI Gateway (pay-as-you-go; cents per chat)
# Get a key: https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=vck_REPLACE_ME

# Native app API base for EAS/TestFlight builds.
# Set this to your deployed Expo API routes host, for example:
# EXPO_PUBLIC_API_BASE_URL=https://voyage.expo.app
EXPO_PUBLIC_API_BASE_URL=
